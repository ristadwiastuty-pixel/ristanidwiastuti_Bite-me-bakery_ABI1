<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bite Me Bakery 🍪</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --cream:#FFF7ED;
    --light-brown:#D8A47F;
    --mid-brown:#A9713F;
    --deep-brown:#5C3A21;
    --pink:#F6C6C0;
    --yellow:#FCE4B8;
    --white:#FFFFFF;
    --shadow: 0 8px 20px rgba(92,58,33,0.15);
    --radius: 24px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{
    font-family:'Quicksand', sans-serif;
    background:var(--cream);
    color:var(--deep-brown);
    overflow-x:hidden;
  }
  h1,h2,h3,.brand,.btn,.nav-link,.cat-title{
    font-family:'Baloo 2', cursive;
  }
  a{text-decoration:none; color:inherit;}
  ul{list-style:none;}
  img{max-width:100%; display:block;}

  /* ===== LAYOUT ===== */
  .app{
    display:flex;
    min-height:100vh;
  }
  /* SIDEBAR */
  .sidebar{
    width:230px;
    background:linear-gradient(180deg,var(--light-brown),var(--mid-brown));
    color:var(--white);
    padding:26px 18px;
    position:sticky;
    top:0;
    height:100vh;
    overflow-y:auto;
    flex-shrink:0;
    z-index:50;
    transition:transform .3s ease;
  }
  .sidebar .brand{
    font-size:1.5rem;
    display:flex;
    align-items:center;
    gap:8px;
    margin-bottom:26px;
  }
  .sidebar h4{
    font-size:.75rem;
    letter-spacing:1px;
    text-transform:uppercase;
    opacity:.75;
    margin:18px 0 8px;
  }
  .nav-link{
    display:flex;
    align-items:center;
    gap:10px;
    padding:10px 12px;
    border-radius:14px;
    font-size:.95rem;
    font-weight:600;
    margin-bottom:4px;
    cursor:pointer;
    transition:background .2s;
  }
  .nav-link:hover, .nav-link.active{
    background:rgba(255,255,255,0.22);
  }
  .sidebar-close{
    display:none;
    position:absolute;
    top:14px; right:14px;
    background:none;
    border:none;
    color:var(--white);
    font-size:1.4rem;
    cursor:pointer;
  }
  .menu-toggle{
    display:none;
    background:var(--deep-brown);
    color:var(--white);
    border:none;
    border-radius:12px;
    padding:8px 12px;
    font-size:1.2rem;
    cursor:pointer;
  }

  /* MAIN */
  .main{
    flex:1;
    min-width:0;
  }
  .topbar{
    display:flex;
    align-items:center;
    gap:16px;
    padding:16px 28px;
    background:var(--white);
    position:sticky;
    top:0;
    z-index:40;
    box-shadow:0 2px 10px rgba(92,58,33,0.06);
  }
  .search-wrap{
    flex:1;
    display:flex;
    align-items:center;
    background:var(--cream);
    border:2px solid var(--light-brown);
    border-radius:30px;
    padding:6px 6px 6px 18px;
    max-width:520px;
  }
  .search-wrap input{
    flex:1;
    border:none;
    background:transparent;
    outline:none;
    font-family:'Quicksand';
    font-size:.95rem;
    color:var(--deep-brown);
  }
  .search-wrap button{
    border:none;
    background:var(--mid-brown);
    color:var(--white);
    width:38px; height:38px;
    border-radius:50%;
    cursor:pointer;
    font-size:1rem;
  }
  .cart-btn{
    position:relative;
    background:var(--deep-brown);
    color:var(--white);
    border:none;
    width:46px; height:46px;
    border-radius:50%;
    font-size:1.25rem;
    cursor:pointer;
    flex-shrink:0;
  }
  .cart-badge{
    position:absolute;
    top:-4px; right:-4px;
    background:var(--pink);
    color:var(--deep-brown);
    font-size:.7rem;
    font-weight:700;
    padding:2px 6px;
    border-radius:10px;
    border:2px solid var(--white);
  }

  /* HERO */
  .hero-section{
    padding:30px 28px 10px;
  }
  .welcome{
    text-align:center;
    margin-bottom:20px;
  }
  .welcome h1{
    font-size:2rem;
    color:var(--mid-brown);
  }
  .welcome p{
    font-size:1.05rem;
    margin-top:6px;
    color:var(--deep-brown);
  }
  .hero-slider{
    position:relative;
    max-width:900px;
    margin:0 auto;
    border-radius:var(--radius);
    overflow:hidden;
    box-shadow:var(--shadow);
    height:280px;
  }
  .hero-track{
    display:flex;
    height:100%;
    transition:transform .5s ease;
  }
  .hero-slide{
    min-width:100%;
    height:100%;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0 40px;
    cursor:pointer;
    color:var(--white);
  }
  .hero-slide .info h2{ font-size:1.7rem; margin-top:6px;}
  .hero-slide .info p{ margin-top:6px; font-size:1.1rem; font-weight:700;}
  .hero-slide .info p.desc{
    font-size:.85rem;
    font-weight:500;
    font-family:'Quicksand';
    max-width:320px;
    opacity:.95;
    line-height:1.4;
  }
  .bestseller-tag{
    display:inline-block;
    background:var(--pink);
    color:var(--deep-brown);
    font-family:'Baloo 2';
    font-weight:700;
    font-size:.75rem;
    padding:4px 12px;
    border-radius:20px;
  }
  .card-badge{
    display:inline-block;
    background:var(--pink);
    color:var(--deep-brown);
    font-family:'Baloo 2';
    font-weight:700;
    font-size:.68rem;
    padding:3px 10px;
    border-radius:14px;
    margin-bottom:6px;
  }
  .hero-slide .info span{
    display:inline-block;
    margin-top:14px;
    background:var(--white);
    color:var(--deep-brown);
    padding:8px 18px;
    border-radius:20px;
    font-family:'Baloo 2';
    font-weight:700;
    font-size:.85rem;
  }
  .hero-slide img{
    width:180px; height:180px;
    border-radius:50%;
    object-fit:cover;
    border:6px solid rgba(255,255,255,0.6);
  }
  .hero-arrow{
    position:absolute;
    top:50%; transform:translateY(-50%);
    background:rgba(255,255,255,0.85);
    border:none;
    width:40px; height:40px;
    border-radius:50%;
    font-size:1.1rem;
    cursor:pointer;
    color:var(--deep-brown);
    z-index:5;
  }
  .hero-arrow.left{left:14px;}
  .hero-arrow.right{right:14px;}
  .hero-dots{
    display:flex;
    justify-content:center;
    gap:8px;
    margin-top:12px;
  }
  .hero-dots span{
    width:9px; height:9px;
    border-radius:50%;
    background:var(--light-brown);
    opacity:.4;
  }
  .hero-dots span.active{opacity:1; background:var(--mid-brown);}

  /* CATALOG */
  .catalog{
    padding:20px 28px 60px;
  }
  .cat-title{
    font-size:1.4rem;
    color:var(--mid-brown);
    margin:34px 0 16px;
    display:flex;
    align-items:center;
    gap:10px;
  }
  .cat-title::after{
    content:"";
    flex:1;
    height:2px;
    background:var(--light-brown);
    opacity:.4;
    border-radius:2px;
  }
  .product-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(190px,1fr));
    gap:26px;
  }
  .product-card{
    background:var(--white);
    border-radius:26px;
    padding:18px 14px 16px;
    text-align:center;
    box-shadow:var(--shadow);
    transition:transform .2s;
    scroll-margin-top:100px;
  }
  .product-card:hover{transform:translateY(-6px);}
  .product-card.highlight{
    outline:3px solid var(--pink);
    animation:pulse 1s ease 2;
  }
  @keyframes pulse{
    0%,100%{box-shadow:var(--shadow);}
    50%{box-shadow:0 0 0 10px rgba(246,198,192,0.4);}
  }
  .bite-circle{
    width:140px; height:140px;
    margin:0 auto 12px;
    position:relative;
  }
  .bite-circle img{
    width:100%; height:100%;
    object-fit:cover;
    border-radius:50%;
    background:var(--yellow);
    -webkit-mask-image:
      radial-gradient(circle 20px at 88% 22%, transparent 98%, black 100%),
      radial-gradient(circle at center, black 100%, black 100%);
    -webkit-mask-composite: source-in, xor;
    mask-composite: intersect;
    mask-image:
      radial-gradient(circle 20px at 88% 22%, transparent 98%, black 100%),
      radial-gradient(circle at center, black 100%, black 100%);
  }
  .product-card h3{
    font-size:1rem;
    margin-bottom:4px;
    color:var(--deep-brown);
  }
  .card-desc{
    font-size:.72rem;
    color:var(--deep-brown);
    opacity:.75;
    line-height:1.35;
    margin-bottom:8px;
    font-family:'Quicksand';
  }
  .product-card .price{
    color:var(--mid-brown);
    font-weight:700;
    margin-bottom:6px;
    font-family:'Baloo 2';
  }
  .rating{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:5px;
    margin-bottom:10px;
    flex-wrap:wrap;
  }
  .rating .stars{
    color:#E8A93B;
    font-size:.85rem;
    letter-spacing:1px;
  }
  .rating .rating-num{
    font-size:.78rem;
    font-weight:700;
    color:var(--deep-brown);
  }
  .rating .rating-count{
    font-size:.68rem;
    opacity:.6;
  }

  /* REVIEWS */
  .reviews{
    padding:10px 28px 50px;
  }
  .review-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(240px,1fr));
    gap:20px;
  }
  .review-card{
    background:var(--white);
    border-radius:20px;
    padding:18px;
    box-shadow:var(--shadow);
  }
  .review-top{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:8px;
  }
  .review-avatar{
    width:42px; height:42px;
    border-radius:50%;
    background:var(--light-brown);
    color:var(--white);
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Baloo 2';
    font-weight:700;
    flex-shrink:0;
  }
  .review-top .rname{
    font-weight:700;
    font-size:.9rem;
    color:var(--deep-brown);
  }
  .review-top .rprod{
    font-size:.75rem;
    color:var(--mid-brown);
    font-weight:600;
  }
  .review-card .stars{
    color:#E8A93B;
    font-size:.85rem;
    letter-spacing:1px;
    display:block;
    margin-bottom:6px;
  }
  .review-card p{
    font-size:.85rem;
    color:var(--deep-brown);
    line-height:1.5;
  }
  .btn{
    border:none;
    border-radius:20px;
    padding:9px 18px;
    font-size:.85rem;
    font-weight:700;
    cursor:pointer;
    background:var(--light-brown);
    color:var(--white);
    transition:background .2s;
  }
  .btn:hover{background:var(--mid-brown);}
  .btn.secondary{
    background:var(--cream);
    color:var(--mid-brown);
    border:2px solid var(--light-brown);
  }
  .btn.block{width:100%;}

  /* CONTACT */
  .contact{
    background:var(--deep-brown);
    color:var(--white);
    padding:40px 28px;
  }
  .contact h2{ font-size:1.5rem; margin-bottom:18px; color:var(--yellow); }
  .contact-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
    gap:20px;
  }
  .contact-item{
    display:flex;
    align-items:center;
    gap:12px;
    background:rgba(255,255,255,0.08);
    padding:14px 16px;
    border-radius:16px;
    transition:background .2s;
  }
  .contact-item:hover{background:rgba(255,255,255,0.18);}
  .contact-item .icon{
    width:40px;height:40px;
    border-radius:50%;
    background:var(--light-brown);
    display:flex;align-items:center;justify-content:center;
    font-size:1.1rem;
    flex-shrink:0;
  }
  .contact-item small{opacity:.75; display:block; font-size:.7rem;}

  /* ===== CART DRAWER ===== */
  .overlay{
    position:fixed; inset:0;
    background:rgba(92,58,33,0.45);
    display:none;
    z-index:200;
  }
  .overlay.show{display:block;}
  .drawer{
    position:fixed;
    top:0; right:0;
    width:360px; max-width:92vw;
    height:100vh;
    background:var(--cream);
    box-shadow:-6px 0 20px rgba(0,0,0,0.2);
    transform:translateX(100%);
    transition:transform .3s ease;
    z-index:210;
    display:flex;
    flex-direction:column;
  }
  .drawer.show{transform:translateX(0);}
  .drawer-header{
    padding:20px;
    background:var(--light-brown);
    color:var(--white);
    display:flex;
    justify-content:space-between;
    align-items:center;
  }
  .drawer-header button{
    background:none; border:none; color:var(--white);
    font-size:1.3rem; cursor:pointer;
  }
  .drawer-body{
    flex:1;
    overflow-y:auto;
    padding:16px 20px;
  }
  .cart-item{
    display:flex;
    gap:10px;
    align-items:center;
    background:var(--white);
    border-radius:14px;
    padding:10px;
    margin-bottom:10px;
  }
  .cart-item img{width:50px;height:50px;border-radius:50%; object-fit:cover;}
  .cart-item .ci-info{flex:1;}
  .cart-item .ci-info h4{font-size:.9rem;}
  .cart-item .ci-info span{font-size:.8rem; color:var(--mid-brown); font-weight:700;}
  .qty-ctrl{display:flex; align-items:center; gap:6px;}
  .qty-ctrl button{
    width:24px;height:24px;border-radius:50%;border:none;
    background:var(--light-brown); color:var(--white); cursor:pointer;
  }
  .remove-btn{
    background:none;border:none;color:#b33; cursor:pointer; font-size:.9rem;
  }
  .drawer-footer{
    padding:16px 20px 22px;
    border-top:2px solid var(--light-brown);
    background:var(--white);
  }
  .total-row{
    display:flex; justify-content:space-between;
    font-family:'Baloo 2'; font-size:1.1rem;
    margin-bottom:12px; color:var(--deep-brown);
  }
  .drawer-footer .actions{display:flex; gap:10px;}
  .empty-msg{text-align:center; opacity:.6; padding:30px 10px; font-size:.9rem;}

  /* ===== MODAL (order + payment) ===== */
  .modal-bg{
    position:fixed; inset:0;
    background:rgba(92,58,33,0.5);
    display:none;
    align-items:center; justify-content:center;
    z-index:300;
    padding:16px;
  }
  .modal-bg.show{display:flex;}
  .modal-box{
    background:var(--white);
    border-radius:22px;
    max-width:480px; width:100%;
    max-height:88vh;
    overflow-y:auto;
    padding:26px;
    position:relative;
    animation:pop .25s ease;
  }
  @keyframes pop{from{transform:scale(.9); opacity:0;} to{transform:scale(1); opacity:1;}}
  .modal-box h2{ color:var(--mid-brown); margin-bottom:14px; font-size:1.3rem;}
  .modal-close{
    position:absolute; top:14px; right:16px;
    background:none;border:none;font-size:1.3rem;cursor:pointer;color:var(--mid-brown);
  }
  .field{margin-bottom:14px;}
  .field label{
    display:block; font-size:.85rem; font-weight:700; margin-bottom:5px; color:var(--deep-brown);
  }
  .field input, .field textarea{
    width:100%;
    padding:10px 12px;
    border-radius:12px;
    border:2px solid var(--light-brown);
    font-family:'Quicksand';
    font-size:.9rem;
    outline:none;
    background:var(--cream);
  }
  .order-items{
    background:var(--cream);
    border-radius:14px;
    padding:10px 14px;
    margin-bottom:14px;
    font-size:.85rem;
  }
  .order-items div{display:flex; justify-content:space-between; padding:4px 0;}
  .pay-options{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
    margin-bottom:16px;
  }
  .pay-option{
    border:2px solid var(--light-brown);
    border-radius:14px;
    padding:10px;
    display:flex;
    align-items:center;
    gap:8px;
    cursor:pointer;
    font-size:.8rem;
    font-weight:700;
  }
  .pay-option.selected{
    background:var(--pink);
    border-color:var(--mid-brown);
  }
  .pay-logo{
    width:32px;height:32px;border-radius:8px;
    display:flex;align-items:center;justify-content:center;
    color:#fff; font-size:.65rem; font-family:'Baloo 2'; flex-shrink:0;
  }
  .logo-cash{background:#5C8A3A;}
  .logo-qris{background:#00695C;}
  .logo-bni{background:#F26522;}
  .logo-dana{background:#118EEA;}

  .payment-detail{
    text-align:center;
    background:var(--cream);
    border-radius:16px;
    padding:18px;
    margin-top:6px;
  }
  .payment-detail img{margin:10px auto; border-radius:10px;}
  .payment-detail .rek{
    font-family:'Baloo 2';
    font-size:1.1rem;
    color:var(--mid-brown);
    margin:8px 0;
    letter-spacing:1px;
  }
  .payment-detail .grand-total{
    font-family:'Baloo 2';
    font-size:1.3rem;
    color:var(--deep-brown);
    margin-top:10px;
  }

  .proof-section{
    margin-top:16px;
    padding-top:14px;
    border-top:2px dashed var(--light-brown);
  }
  .proof-section label{
    display:block;
    font-size:.85rem;
    font-weight:700;
    color:var(--deep-brown);
    margin-bottom:6px;
  }
  .proof-section input[type="file"]{
    width:100%;
    font-size:.8rem;
    padding:8px;
    border:2px solid var(--light-brown);
    border-radius:12px;
    background:var(--cream);
  }
  .proof-section img{
    margin-top:10px;
    width:100%;
    max-height:180px;
    object-fit:contain;
    border-radius:12px;
    border:2px solid var(--light-brown);
  }
  .proof-note{
    font-size:.72rem;
    opacity:.75;
    margin:8px 0 10px;
    line-height:1.4;
  }
  .wa-btn{
    background:#25D366;
  }
  .wa-btn:hover{
    background:#1ebe5a;
  }

  footer.copyright{
    text-align:center;
    padding:14px;
    background:var(--deep-brown);
    color:var(--yellow);
    font-size:.8rem;
    opacity:.85;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px){
    .sidebar{
      position:fixed;
      left:0; top:0;
      transform:translateX(-100%);
      box-shadow:6px 0 20px rgba(0,0,0,0.2);
    }
    .sidebar.show{transform:translateX(0);}
    .sidebar-close{display:block;}
    .menu-toggle{display:inline-block;}
  }
  @media (max-width:600px){
    .hero-slider{height:340px;}
    .hero-slide{flex-direction:column-reverse; justify-content:center; gap:14px; padding:20px;}
    .hero-slide .info{text-align:center;}
    .hero-slide img{width:120px;height:120px;}
    .topbar{padding:12px 14px;}
    .catalog{padding:14px 14px 40px;}
    .hero-section{padding:16px 14px 6px;}
  }
</style>
</head>
<body>

<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <button class="sidebar-close" onclick="toggleSidebar(false)">✕</button>
    <div class="brand">🍩 Bite Me Bakery</div>

    <h4>Menu</h4>
    <div class="nav-link" onclick="scrollToId('top')">🏠 Beranda</div>
    <div class="nav-link" onclick="scrollToId('katalog')">📖 Katalog Produk</div>
    <div class="nav-link" onclick="scrollToId('ulasan')">💬 Ulasan Pelanggan</div>
    <div class="nav-link" onclick="scrollToId('kontak')">☎️ Kontak</div>

    <h4>Kategori Produk</h4>
    <div class="nav-link" onclick="scrollToId('kat-mochi')">🍪 Mochi &amp; Cookies</div>
    <div class="nav-link" onclick="scrollToId('kat-cake')">🎂 Cake &amp; Brownies</div>
    <div class="nav-link" onclick="scrollToId('kat-pastry')">🥐 Pastry</div>
    <div class="nav-link" onclick="scrollToId('kat-cupcake')">🧁 Cupcake</div>
  </aside>

  <!-- MAIN -->
  <div class="main" id="top">
    <div class="topbar">
      <button class="menu-toggle" onclick="toggleSidebar(true)">☰</button>
      <div class="search-wrap">
        <input type="text" id="searchInput" placeholder="Cari produk favoritmu... (mis: donut, cookie)" onkeydown="if(event.key==='Enter')doSearch()">
        <button onclick="doSearch()">🔍</button>
      </div>
      <button class="cart-btn" onclick="toggleCart(true)">🛒<span class="cart-badge" id="cartBadge">0</span></button>
    </div>

    <!-- HERO -->
    <section class="hero-section">
      <div class="welcome">
