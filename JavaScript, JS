
/* ===================== DATA ===================== */
const cart = {}; // id -> {name, price, img, qty}

/* ===================== HERO CAROUSEL ===================== */
const heroTrack = document.getElementById('heroTrack');
const slides = document.querySelectorAll('.hero-slide');
const heroDots = document.getElementById('heroDots');
let heroIndex = 0;
slides.forEach((s,i)=>{
  const dot = document.createElement('span');
  if(i===0) dot.className='active';
  heroDots.appendChild(dot);
  s.addEventListener('click', ()=>{
    const target = document.querySelector(`[data-id="${s.dataset.target}"]`);
    if(target){ target.scrollIntoView({behavior:'smooth', block:'center'}); flashHighlight(target); }
  });
});
function updateHero(){
  heroTrack.style.transform = `translateX(-${heroIndex*100}%)`;
  document.querySelectorAll('.hero-dots span').forEach((d,i)=> d.className = i===heroIndex ? 'active':'');
}
function moveHero(dir){
  heroIndex = (heroIndex + dir + slides.length) % slides.length;
  updateHero();
}
setInterval(()=>moveHero(1), 6000);

function flashHighlight(el){
  el.style.transition='box-shadow .3s';
  el.querySelector('.product-circle').style.boxShadow='0 0 0 6px var(--pink-accent)';
  setTimeout(()=> el.querySelector('.product-circle').style.boxShadow='', 1400);
}

/* ===================== SIDEBAR MOBILE ===================== */
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('overlay');
document.getElementById('menuToggle').onclick = ()=>{ sidebar.classList.add('open'); overlay.classList.add('show'); };
overlay.onclick = ()=>{ sidebar.classList.remove('open'); overlay.classList.remove('show'); };
document.querySelectorAll('.nav-link').forEach(l=> l.addEventListener('click', (e)=>{
  e.preventDefault();
  document.querySelectorAll('.nav-link').forEach(n=>n.classList.remove('active'));
  l.classList.add('active');
  const targetEl = document.getElementById(l.dataset.target);
  if(targetEl) targetEl.scrollIntoView({behavior:'smooth', block:'start'});
  sidebar.classList.remove('open'); overlay.classList.remove('show');
}));

/* ===================== SEARCH ===================== */
const products = Array.from(document.querySelectorAll('.product-card')).map(c=>({
  id:c.dataset.id, name:c.dataset.name, price:Number(c.dataset.price), img:c.dataset.img, el:c
}));
const searchInput = document.getElementById('searchInput');
const searchResults = document.getElementById('searchResults');
searchInput.addEventListener('input', doSearch);
function doSearch(){
  const q = searchInput.value.trim().toLowerCase();
  if(!q){ searchResults.classList.remove('show'); searchResults.innerHTML=''; return; }
  const matches = products.filter(p=>p.name.toLowerCase().includes(q));
  if(matches.length===0){
    searchResults.innerHTML = `<div class="search-result-item"><span>Produk tidak ditemukan 😢</span></div>`;
  } else {
    searchResults.innerHTML = matches.map(p=>`
      <div class="search-result-item" data-id="${p.id}">
        <img src="${p.img}"><span>${p.name} — Rp ${p.price.toLocaleString('id-ID')}</span>
      </div>`).join('');
  }
  searchResults.classList.add('show');
}
searchResults.addEventListener('click', (e)=>{
  const item = e.target.closest('.search-result-item');
  if(!item || !item.dataset.id) return;
  const prod = products.find(p=>p.id===item.dataset.id);
  if(prod){
    prod.el.scrollIntoView({behavior:'smooth', block:'center'});
    flashHighlight(prod.el);
    searchResults.classList.remove('show');
    searchInput.value='';
  }
});
document.addEventListener('click', (e)=>{
  if(!e.target.closest('.search-wrap')) searchResults.classList.remove('show');
});

/* ===================== CART ===================== */
const cartPanel = document.getElementById('cartPanel');
document.getElementById('openCart').onclick = ()=> cartPanel.classList.add('open');
document.getElementById('closeCart').onclick = ()=> cartPanel.classList.remove('open');

function quickAdd(e){
  e.stopPropagation();
  const card = e.target.closest('.product-card');
  addToCart(card.dataset.id, card.dataset.name, Number(card.dataset.price), card.dataset.img);
}
function addToCart(id, name, price, img){
  if(cart[id]) cart[id].qty++;
  else cart[id] = {name, price, img, qty:1};
  renderCart();
  showToast(`${name} ditambahkan ke keranjang ✨`);
}
function changeQty(id, delta){
  if(!cart[id]) return;
  cart[id].qty += delta;
  if(cart[id].qty<=0) delete cart[id];
  renderCart();
}
function removeItem(id){ delete cart[id]; renderCart(); }

function renderCart(){
  const wrap = document.getElementById('cartItems');
  const ids = Object.keys(cart);
  let total=0, count=0;
  if(ids.length===0){
    wrap.innerHTML = `<div class="empty-cart">Keranjang masih kosong 🍪<br>Yuk pilih kue favoritmu!</div>`;
  } else {
    wrap.innerHTML = ids.map(id=>{
      const it = cart[id];
      total += it.price*it.qty;
      count += it.qty;
      return `<div class="cart-item">
        <img src="${it.img}">
        <div class="info">
          <div class="name">${it.name}</div>
          <div class="price">Rp ${it.price.toLocaleString('id-ID')}</div>
          <div class="qty-control">
            <button onclick="changeQty('${id}',-1)">−</button>
            <span>${it.qty}</span>
            <button onclick="changeQty('${id}',1)">+</button>
            <span class="remove-item" onclick="removeItem('${id}')">Hapus</span>
          </div>
        </div>
      </div>`;
    }).join('');
  }
  document.getElementById('cartTotal').textContent = 'Rp ' + total.toLocaleString('id-ID');
  document.getElementById('cartCount').textContent = count;
  window._cartTotal = total;
}
document.getElementById('resetCart').onclick = ()=>{
  Object.keys(cart).forEach(k=>delete cart[k]);
  renderCart();
  showToast('Keranjang direset 🗑️');
};

/* ===================== TOAST ===================== */
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=> t.classList.remove('show'), 2200);
}

/* ===================== ORDER MODAL ===================== */
const orderModal = document.getElementById('orderModal');
document.getElementById('checkoutBtn').onclick = ()=>{
  if(Object.keys(cart).length===0){ showToast('Keranjang masih kosong, yuk pilih dulu! 🧁'); return; }
  buildOrderSummary();
  orderModal.classList.add('show');
  cartPanel.classList.remove('open');
};
document.getElementById('closeOrderModal').onclick = ()=> orderModal.classList.remove('show');

function buildOrderSummary(){
  const sum = document.getElementById('orderSummary');
  let total=0;
  let html = Object.values(cart).map(it=>{
    total += it.price*it.qty;
    return `<div><span>${it.name} x${it.qty}</span><span>Rp ${(it.price*it.qty).toLocaleString('id-ID')}</span></div>`;
  }).join('');
  html += `<div class="grand"><span>Total</span><span>Rp ${total.toLocaleString('id-ID')}</span></div>`;
  sum.innerHTML = html;
  window._orderTotal = total;
}

document.querySelectorAll('.pay-option').forEach(opt=>{
  opt.addEventListener('click', ()=>{
    document.querySelectorAll('.pay-option').forEach(o=>o.classList.remove('selected'));
    opt.classList.add('selected');
    opt.querySelector('input').checked = true;
  });
});

/* ===================== PAYMENT POPUP ===================== */
const payPopup = document.getElementById('payPopup');
document.getElementById('lanjutBayar').onclick = ()=>{
  const name = document.getElementById('ordName').value.trim();
  const address = document.getElementById('ordAddress').value.trim();
  const ig = document.getElementById('ordIG').value.trim();
  const phone = document.getElementById('ordPhone').value.trim();
  const method = document.querySelector('input[name="payMethod"]:checked');

  if(!name || !address || !phone){ showToast('Mohon lengkapi nama, alamat & no HP ya 😊'); return; }
  if(!method){ showToast('Pilih metode pembayaran dulu ya 💳'); return; }

  const total = window._orderTotal || 0;
  const payTitle = document.getElementById('payTitle');
  const payContent = document.getElementById('payContent');
  document.getElementById('payTotal').textContent = 'Rp ' + total.toLocaleString('id-ID');

  const qrisImage = "data:image/jpeg;base64,";

  if(method.value==='cash'){
    payTitle.textContent = '💵 Pembayaran Cash';
    payContent.innerHTML = `<p style="font-size:13.5px;color:var(--milk-choco-dark);margin-bottom:14px;">Silakan siapkan uang tunai. Pembayaran dilakukan saat pesanan tiba / diambil di toko ya~</p>`;
  } else if(method.value==='qris'){
    payTitle.textContent = '📲 Scan QRIS';
    payContent.innerHTML = `<div class="qr-box" style="height:auto;"><img src="${qrisImage}" alt="QRIS Bite Me Bakery" style="width:100%;display:block;"></div><p style="font-size:12px;color:var(--milk-choco-dark);margin-top:8px;">Scan QR di atas pakai aplikasi e-wallet / m-banking favoritmu ya~</p>`;
  } else if(method.value==='bni'){
    payTitle.textContent = '🏦 Transfer Bank BNI';
    payContent.innerHTML = `<div class="rek-box">
      <div class="bank">a.n. Rista Dwi Astuty — BNI</div>
      <div class="nomor">1980211429</div>
      <button class="copy-btn" onclick="copyText('1980211429')">Salin No. Rekening</button>
    </div>`;
  } else if(method.value==='dana'){
    payTitle.textContent = '💳 Transfer DANA';
    payContent.innerHTML = `<div class="rek-box">
      <div class="bank">a.n. Rista Dwi Astuty — DANA</div>
      <div class="nomor">083844266007</div>
      <button class="copy-btn" onclick="copyText('083844266007')">Salin No. DANA</button>
    </div>`;
  }

  payPopup.classList.add('show');

  document.getElementById('confirmOrder').onclick = ()=>{
    const items = Object.values(cart).map(it=>`- ${it.name} x${it.qty} (Rp ${(it.price*it.qty).toLocaleString('id-ID')})`).join('%0A');
    const msg = `Halo Bite Me Bakery! Saya ingin pesan:%0A${items}%0A%0ATotal: Rp ${total.toLocaleString('id-ID')}%0A%0ANama: ${name}%0AAlamat: ${address}%0AInstagram: ${ig}%0ANo HP: ${phone}%0AMetode Bayar: ${method.value.toUpperCase()}`;
    window.open(`https://wa.me/6283844266007?text=${msg}`, '_blank');
  };
};
document.getElementById('closePayPopup').onclick = ()=> payPopup.classList.remove('show');

function copyText(t){
  navigator.clipboard.writeText(t).then(()=> showToast('Nomor disalin! 📋'));
}
